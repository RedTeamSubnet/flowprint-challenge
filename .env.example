## --- Environment variable --- ##
ENV=LOCAL
DEBUG=false
# TZ=UTC
# PYTHONDONTWRITEBYTECODE=1


## -- API configs -- ##
FLR_API_PORT=10001
# FLR_API_CONFIGS_DIR="/etc/flowradar-challenge"
# FLR_API_LOGS_DIR="/var/log/flowradar-challenge"
# FLR_API_TMP_DIR="/tmp/flowradar-challenge"
# FLR_API_VERSION="1"
# FLR_API_PREFIX=""
# FLR_API_DOCS_ENABLED=true
# FLR_API_DOCS_OPENAPI_URL="{api_prefix}/openapi.json"
# FLR_API_DOCS_DOCS_URL="{api_prefix}/docs"
# FLR_API_DOCS_REDOC_URL="{api_prefix}/redoc"

FLR_CHALLENGE_API_KEY="your_api_key_here" # pragma: allowlist secret

## -- Challenge data and v2 model training configs -- ##
## The compose file mounts ./volumes/storage/flowradar-challenge/data here.
FLR_API_DATA_DIR="/var/lib/flowradar-challenge"

## Scoring replays this CSV through the detector container.
FLR_CHALLENGE_TEST_CSV_PATH="{data_dir}/v2_test_data.csv"

## Mandatory production dataset passed to miner train.py as argv[1].
FLR_CHALLENGE_TRAIN_CSV_PATH="{data_dir}/v2_train_data.csv"

## Maximum training time in seconds.
FLR_CHALLENGE_TRAINING_TIMEOUT_SECONDS=600

## Maximum generated JSON model size in bytes. Default is 20 MiB.
# FLR_CHALLENGE_MODEL_JSON_SIZE_LIMIT=20971520
