## --- Environment variable --- ##
ENV=LOCAL
DEBUG=false
# TZ=UTC
# PYTHONDONTWRITEBYTECODE=1


## -- API configs -- ##
FLP_API_PORT=10001
# FLP_API_CONFIGS_DIR="/etc/flowprint-challenge"
# FLP_API_LOGS_DIR="/var/log/flowprint-challenge"
# FLP_API_TMP_DIR="/tmp/flowprint-challenge"
# FLP_API_VERSION="1"
# FLP_API_PREFIX=""
# FLP_API_DOCS_ENABLED=true
# FLP_API_DOCS_OPENAPI_URL="{api_prefix}/openapi.json"
# FLP_API_DOCS_DOCS_URL="{api_prefix}/docs"
# FLP_API_DOCS_REDOC_URL="{api_prefix}/redoc"

FLP_CHALLENGE_API_KEY="your_api_key_here" # pragma: allowlist secret

## -- Challenge data and v2 model training configs -- ##
## The compose file mounts ./volumes/storage/flowprint-challenge/data here.
FLP_API_DATA_DIR="/var/lib/flowprint-challenge"

## Scoring replays this CSV through the detector container.
FLP_CHALLENGE_TEST_CSV_PATH="{data_dir}/v2_test_data.csv"

## Mandatory production dataset passed to miner train.py as argv[1].
FLP_CHALLENGE_TRAIN_CSV_PATH="{data_dir}/v2_train_data.csv"

## Maximum training time in seconds.
FLP_CHALLENGE_TRAINING_TIMEOUT_SECONDS=600

## Maximum generated JSON model size in bytes. Default is 20 MiB.
# FLP_CHALLENGE_MODEL_JSON_SIZE_LIMIT=20971520
